	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="penjualan"/>
	<parameter name="id_nota" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
	nota.idnota AS idnota,
	nota.date AS tgl_nota,
	nota.id AS id_pelanggan,
	nota.id_kasir AS id_kasir,
	pelanggan.nmplg AS nmplg,
	pelanggan.jenis AS jenis_pelanggan,
	pelanggan.telepon AS telepon,
	pelanggan.alamat AS alamat_pelanggan,
	kasir.nm_kasir AS nm_kasir,
	kasir.jenis_kelamin AS jenis_kelamin,
	kasir.no_telepon AS no_telepon,
	kasir.agama AS agama,
	kasir.alamat AS alamat_kasir,
	isi.id_barang AS id_barang,
	CAST(isi.qty AS UNSIGNED) AS qty,
	barang.nama_barang AS nama_barang,
	barang.jenis AS jenis_barang,
	barang.harga_beli AS harga_beli,
	barang.harga_jual AS harga_jual
FROM nota
JOIN pelanggan ON nota.id = pelanggan.id
JOIN kasir ON nota.id_kasir = kasir.id_kasir
JOIN isi ON isi.idnota = nota.idnota
JOIN barang ON isi.id_barang = barang.id_barang
WHERE nota.idnota = $P{id_nota}]]>
	</queryString>
